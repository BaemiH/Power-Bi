	partition DimDateTable-8bae9646-3e9d-4f14-b089-190e392db6ec = calculated
		mode: import
		source = ```
				ADDCOLUMNS( CALENDARAUTO(), //CALENDAR(min('Demand Template'[date]), max('Demand Template'[Date])),
				"DateAsInteger", FORMAT ( [Date], "YYYYMMDD" ), 
				"Year",         YEAR ( [Date] ), 
				"MonthNo",      FORMAT ( [Date], "MM" ), 
				"YearMonthNo",  FORMAT ( [Date], "YYYY/MM" ), 
				"YearMonth",    FORMAT ( [Date], "YYYY/mmm" ), 
				"Month Short",  FORMAT ( [Date], "mmm" ), 
				"Month Long",   FORMAT ( [Date], "mmmm" ), 
				"WeekNo",       WEEKDAY( [Date] ), 
				"Weekday",      FORMAT ( [Date], "dddd" ), 
				"Quarter", "Q" & FORMAT( [Date], "Q" ), 
				"YearQuarter",  FORMAT ( [Date], "YYYY" ) & "/Q" & FORMAT ( [Date], "Q" ),
				"Month-Year",   FORMAT ([Date], "MMM-YY"))
				```

	annotation PBI_Id = 5891dc5cc876426da970171a4642f4ea

